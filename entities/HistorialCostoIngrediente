      "type": "number",
      "description": "Nuevo costo del ingrediente"
    },
    "fecha_cambio": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha y hora del cambio"
    },
    "empleado_nombre": {
      "type": "string",
